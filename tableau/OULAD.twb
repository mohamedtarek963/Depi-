            <column-instance column='[Module_Key (Dim_Modules_Catalog)]' derivation='None' name='[none:Module_Key (Dim_Modules_Catalog):nk]' pivot='key' type='nominal' />
            <column-instance column='[semester]' derivation='None' name='[none:semester:nk]' pivot='key' type='nominal' />
            <column caption='Score' datatype='real' name='[score]' role='measure' type='quantitative' />
            <column caption='Semester' datatype='string' name='[semester]' role='dimension' type='nominal' />
