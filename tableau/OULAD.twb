      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1stwnzz07tc1dn10lmetv0j3ts8w].[ctd:date_unregistration:qk]&quot;' value='Unactive Students' />
        </aliases>
      </column>
      <column caption='Active Students' datatype='integer' name='[Calculation_2268586209234944]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [is_active] = 1 THEN [Student_Key] END)' />
      </column>
      <column caption='Avg Student Score' datatype='real' name='[Calculation_2268586209759233]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([score])' />
      </column>
      <column caption='Total Clicks Per Student' datatype='integer' name='[Calculation_2268586219405314]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Student_Key], [Module_Key] : SUM([sum_click]) }' />
      </column>
      <column caption='Students Risk' datatype='string' name='[Calculation_2268586220597251]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([score]) OR [score] &lt; 60 THEN &quot;High Risk&quot;&#13;&#10;ELSEIF [sum_click] &lt; 10 THEN &quot;Medium Risk&quot;&#13;&#10;ELSE &quot;Low Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Pass Rate.' datatype='real' default-format='p0.0%' name='[Calculation_2268586253438980]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [score] &gt;= 50 THEN 1 ELSE 0 END) / COUNT([score])' />
      </column>
      <column caption='Submission Delay' datatype='integer' name='[Calculation_2268586256556037]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[date] - [date_submitted]' />
      </column>
      <column caption='Module Key (Dim Assessments Info)' datatype='string' name='[Module_Key (Dim_Assessments_Info)]' role='dimension' type='nominal' />
