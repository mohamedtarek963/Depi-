    <worksheet name='D3 - KPI - Pass Rate'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#ffffff'>Pass Rate</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Dim_Students_Profile+ (oulad_warehouse)' name='federated.1stwnzz07tc1dn10lmetv0j3ts8w' />
          </datasources>
          <datasource-dependencies datasource='federated.1stwnzz07tc1dn10lmetv0j3ts8w'>
            <column caption='Total Clicks Per Student' datatype='integer' name='[Calculation_2268586219405314]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Student_Key], [Module_Key] : SUM([sum_click]) }' />
            </column>
            <column caption='Pass Rate.' datatype='real' default-format='p0.0%' name='[Calculation_2268586253438980]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [score] &gt;= 50 THEN 1 ELSE 0 END) / COUNT([score])' />
            </column>
            <column caption='Module Key (Dim Modules Catalog)' datatype='string' name='[Module_Key (Dim_Modules_Catalog)]' role='dimension' type='nominal' />
            <column caption='Module Key' datatype='string' name='[Module_Key]' role='dimension' type='nominal' />
